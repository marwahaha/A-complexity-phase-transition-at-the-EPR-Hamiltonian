Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"aEff", " ", "and", " ", "derivate"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Step", " ", "1"}], ":", 
     RowBox[{
     "Solve", " ", "for", " ", "the", " ", "smallest", " ", "real", " ", 
      "root", " ", "of", " ", "deg12Poly", " ", "at", " ", "b"}]}], "=", 
    "0"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"\[Lambda]0", "=", 
     RowBox[{"Min", "[", 
      RowBox[{"\[Lambda]", "/.", " ", 
       RowBox[{"NSolve", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"deg12Poly", "==", "0"}], "/.", " ", 
          RowBox[{"b", "->", "0"}]}], ",", "\[Lambda]"}], "]"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Step", " ", "2"}], ":", 
      RowBox[{"Compute", " ", 
       RowBox[{"d\[CapitalLambda]", "/", "db"}], " ", "at", " ", "b"}]}], "=", 
     RowBox[{"0", " ", "using", " ", "implicit", " ", "differentiation"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"d\[Lambda]dbAt0", "=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{"deg12Poly", ",", "b"}], "]"}], "/.", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"b", "->", "0"}], ",", 
           RowBox[{"\[Lambda]", "->", "\[Lambda]0"}]}], "}"}]}], ")"}]}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{"deg12Poly", ",", "\[Lambda]"}], "]"}], "/.", " ", 
        RowBox[{"{", 
